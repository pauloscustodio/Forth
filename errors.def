#ifndef X
#define X(id, code, message)
#endif

// The THROW values {-255...-1} shall be used only as assigned by the Standard. 
X(0, ErrorOk, "OK")
X(-1, ErrorAbort, "ABORT")
X(-2, ErrorAbortQuote, "ABORTQuote")
X(-3, ErrorStackOverflow, "stack overflow")
X(-4, ErrorStackUnderflow, "stack underflow")
X(-5, ErrorReturnStackOverflow, "return stack overflow")
X(-6, ErrorReturnStackUnderflow, "return stack underflow")
X(-7, ErrorDoLoopsNestedTooDeeplyDuringExecution, "do-loops nested too deeply during execution")
X(-8, ErrorDictionaryOverflow, "dictionary overflow")
X(-9, ErrorInvalidMemoryAddress, "invalid memory address")
X(-10, ErrorDivisionByZero, "division by zero")
X(-11, ErrorResultOutOfRange, "result out of range")
X(-12, ErrorArgumentTypeMismatch, "argument type mismatch")
X(-13, ErrorUndefinedWord, "undefined word")
X(-14, ErrorInterpretingACompileTimeOnlyWord, "interpreting a compile-only word")
X(-15, ErrorInvalidForget, "invalid FORGET")
X(-16, ErrorAttemptToUseZeroLengthStringAsName, "attempt to use zero-length string as a name")
X(-17, ErrorPicturedNumericOutputStringOverflow, "pictured numeric output string overflow")
X(-18, ErrorParsedStringOverflow, "parsed string overflow")
X(-19, ErrorDefinitionNameTooLong, "definition name too long")
X(-20, ErrorWriteToReadOnlyLocation, "write to a read-only location")
X(-21, ErrorUnsupportedOperation, "unsupported operation")
X(-22, ErrorControlStructureMismatch, "control structure mismatch")
X(-23, ErrorAddressAlignmentException, "address alignment exception")
X(-24, ErrorInvalidNumericArgument, "invalid numeric argument")
X(-25, ErrorReturnStackImbalance, "return stack imbalance")
X(-26, ErrorLoopParametersUnavailable, "loop parameters unavailable")
X(-27, ErrorInvalidRecursion, "invalid recursion")
X(-28, ErrorUserInterrupt, "user interrupt")
X(-29, ErrorCompilerNesting, "compiler nesting")
X(-30, ErrorObsolescentFeature, "obsolescent feature")
X(-31, ErrorToBodyUsedOnNonCreatedDefinition, ">BODY used on non-CREATEd definition")
X(-32, ErrorInvalidNameArgument, "invalid name argument (e.g., TO xxx)")
X(-33, ErrorBlockReadException, "block read exception")
X(-34, ErrorBlockWriteException, "block write exception")
X(-35, ErrorInvalidBlockNumber, "invalid block number")
X(-36, ErrorInvalidFilePosition, "invalid file position")
X(-37, ErrorFileIOException, "file I/O exception")
X(-38, ErrorNonExistentFile, "non-existent file")
X(-39, ErrorUnexpectedEndOfFile, "unexpected end of file")
X(-40, ErrorInvalidBaseForFloatingPointConversion, "invalid BASE for floating point conversion")
X(-41, ErrorLossOfPrecision, "loss of precision")
X(-42, ErrorFloatingPointDivideByZero, "floating-point divide by zero")
X(-43, ErrorFloatingPointResultOutOfRange, "floating-point result out of range")
X(-44, ErrorFloatingPointStackOverflow, "floating-point stack overflow")
X(-45, ErrorFloatingPointStackUnderflow, "floating-point stack underflow")
X(-46, ErrorFloatingPointInvalidArgument, "floating-point invalid argument")
X(-47, ErrorCompilationWordListDeleted, "compilation word list deleted")
X(-48, ErrorInvalidPostpone, "invalid POSTPONE")
X(-49, ErrorSearchOrderOverflow, "search-order overflow")
X(-50, ErrorSearchOrderUnderflow, "search-order underflow")
X(-51, ErrorCompilationWordListChanged, "compilation word list changed")
X(-52, ErrorControlFlowStackOverflow, "control-flow stack overflow")
X(-53, ErrorExceptionStackOverflow, "exception stack overflow")
X(-54, ErrorFloatingPointUnderflow, "floating-point underflow")
X(-55, ErrorFloatingPointUnidentfiedFault, "floating-point unidentified fault")
X(-56, ErrorQuit, "QUIT")
X(-57, ErrorExceptionInSendingOrReceivingACharacter, "exception in sending or receiving a character")
X(-58, ErrorIfElseOrThenException, "[IF], [ELSE], or [THEN] exception")

// The values {-4095...-256} shall be used only as assigned by a system.
X(-256, ErrorInputBufferOverflow, "input buffer overflow")
X(-257, ErrorInvalidNumber, "invalid number")
X(-258, ErrorOutOfMemory, "out of memory")
X(-259, ErrorStringTooLong, "string too long")
X(-260, ErrorControlFlowStackUnderflow, "control-flow stack underflow")
X(-261, ErrorTooManyOpenFiles, "too many open files")
X(-262, ErrorInvalidForthCode, "invalid Forth code")
X(-263, ErrorMemoryOverflow, "memory overflow")

#undef X
