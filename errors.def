#ifndef X
#define X(id, code, message)
#endif

X(-3, ErrorStackOverflow, "stack overflow")
X(-4, ErrorStackUnderflow, "stack underflow")
X(-5, ErrorReturnStackOverflow, "return stack overflow")
X(-6, ErrorReturnStackUnderflow, "return stack underflow")
X(-9, ErrorInvalidMemoryAddress, "invalid memory address")
X(-13, ErrorUndefinedWord, "undefined word")
X(-38, ErrorNonExistentFile, "non-existent file")

#undef X
