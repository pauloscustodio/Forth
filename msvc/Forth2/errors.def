#ifndef X
#define X(, id, message)
#endif

X(ErrorStackOveflow, -3, "stack overflow")
X(ErrorStackUnderflow, -4, "stack underflow")
X(ErrorReturnStackOveflow, -5, "return stack overflow")
X(ErrorReturnStackUnderflow, -6, "return stack underflow")

#undef X
